{
  "name": "egg-shen-bot",
  "version": "1.0.0",
  "description": "Egg Shen - Discord bot for searching movies, TV shows, games, and board games with ratings from multiple services",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "deploy-commands": "node src/deploy-commands.js",
    "validate-oauth": "node scripts/validate-oauth-config.js",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:simulate": "node tests/simulate-tournament.js"
  },
  "keywords": [
    "discord",
    "bot",
    "movies",
    "tv",
    "ratings"
  ],
  "author": "",
  "license": "CC-BY-NC-SA-4.0",
  "dependencies": {
    "@napi-rs/canvas": "^1.0.1",
    "axios": "^1.6.8",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "discord.js": "^14.14.1",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "fast-xml-parser": "^5.9.0",
    "letterboxd-retriever": "^1.1.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "jest": "^29.7.0",
    "playwright": "^1.61.1",
    "supertest": "^7.0.0",
    "vitepress": "^1.6.4"
  }
}
