# Production .env Configuration for Testing

# Use this as your production server .env when testing event requests with your test Discord server
# After testing is successful, you can add real production servers (like Shudder) to event_request_config.json

# ===== Discord Bot Configuration =====
DISCORD_TOKEN=YOUR_BOT_TOKEN_HERE
DISCORD_CLIENT_ID=YOUR_CLIENT_ID_HERE
DISCORD_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE

# ===== API Keys (Required) =====
TMDB_API_KEY=YOUR_TMDB_KEY_HERE

# ===== API Keys (Optional) =====
OMDB_API_KEY=YOUR_OMDB_KEY_HERE
TRAKT_CLIENT_ID=YOUR_TRAKT_KEY_HERE
RAWG_API_KEY=YOUR_RAWG_KEY_HERE
BGG_CLIENT_ID=YOUR_BGG_KEY_HERE
GOOGLE_BOOKS_API_KEY=YOUR_GOOGLE_BOOKS_KEY_HERE
WATCHMODE_API_KEY=YOUR_WATCHMODE_KEY_HERE
OPENAI_API_KEY=YOUR_OPENAI_KEY_HERE
SPOTIFY_CLIENT_ID=YOUR_SPOTIFY_CLIENT_ID_HERE
SPOTIFY_CLIENT_SECRET=YOUR_SPOTIFY_SECRET_HERE

# ===== Event Request API Configuration =====
# IMPORTANT: Configure these for production testing

# Port the API server listens on
API_PORT=3000

# OAuth redirect URI - MUST match Discord Developer Portal exactly
# Format: https://YOUR_SERVER_IP_OR_DOMAIN/api/auth/discord/callback
OAUTH_REDIRECT_URI=http://172.239.155.166:3000/api/auth/discord/callback

# URL of the web form (where users submit requests)
# For testing: Can use your production server IP with port 8080
FORM_URL=http://172.239.155.166:8080

# Allowed origins for CORS (comma-separated)
# Include your server IP and any production domains
ALLOWED_ORIGINS=http://172.239.155.166:8080,https://shudderdrivein.com

# ===== Optional: Guild ID for Testing =====
# Leave empty to deploy commands globally
GUILD_ID=

# ===== Notes =====
# 1. Add this redirect URI to Discord Developer Portal:
#    http://172.239.155.166:3000/api/auth/discord/callback
#
# 2. Start a simple web server on port 8080 to serve the form:
#    cd /opt/discord-bot/public && python3 -m http.server 8080 &
#
# 3. Configure your test server in Discord:
#    /eggshen-config event-requests toggle enabled:true
#    /eggshen-config event-requests moderation-channel channel:#your-channel
#    /eggshen-config event-requests website-url url:http://172.239.155.166:8080
#    /eggshen-config event-requests get-link
#
# 4. Test with the link from step 3
#
# 5. Once testing is successful, you can:
#    - Set up shudderdrivein.com properly
#    - Update FORM_URL and OAUTH_REDIRECT_URI
#    - Add the new redirect URI to Discord Developer Portal
#    - Configure production servers (like Shudder Discord)
