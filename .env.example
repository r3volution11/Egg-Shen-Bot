# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# API Keys (Required)
TMDB_API_KEY=your_tmdb_api_key_here

# API Keys (Optional - commands will be disabled if not provided)
OMDB_API_KEY=your_omdb_api_key_here
TRAKT_CLIENT_ID=your_trakt_client_id_here
RAWG_API_KEY=your_rawg_api_key_here
BGG_CLIENT_ID=your_bgg_client_id_here
GOOGLE_BOOKS_API_KEY=your_google_books_api_key_here

# API Keys (Optional - Enhanced Features)
WATCHMODE_API_KEY=your_watchmode_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Event Request API Configuration
API_PORT=3000
OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback
FORM_URL=http://localhost:8080
ALLOWED_ORIGINS=http://localhost:8080,https://shudderdrivein.com

# Optional: Guild ID for testing (leave empty for global commands)
GUILD_ID=
